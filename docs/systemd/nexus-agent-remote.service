[Unit]
Description=Nexus Agent
After=network.target nexus-core.service

[Service]
Type=simple
User=methinked
Group=methinked
WorkingDirectory=/home/methinked/Projects/nexus/nexus
Environment="PATH=/home/methinked/Projects/nexus/nexus/venv/bin"
Environment="NEXUS_CORE_URL=http://localhost:8000"
# Use HDD for logs/data if needed, or keep default. Let's keep agent lightweight on NVMe for now unless configured otherwise.
# EnvironmentFile=/home/methinked/Projects/nexus/nexus/.env 
# (Agent uses its own config defaults or env vars)

ExecStart=/home/methinked/Projects/nexus/nexus/venv/bin/python -m nexus.agent.main
Restart=always
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nexus-agent

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
# ProtectHome=true 
# Disabled protecthome for home deployment
ReadWritePaths=/home/methinked/Projects/nexus/nexus/data

[Install]
WantedBy=multi-user.target
