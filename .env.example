# Nexus Environment Configuration
# Copy this file to .env and update with your values

# Shared secret for agent registration
# IMPORTANT: Change this in production!
NEXUS_SHARED_SECRET=change-me-in-production

# Core URL (for agents to connect)
# Use local network IP or VPN IP
NEXUS_CORE_URL=http://192.168.1.100:8000

# Agent node name
# Customize for each agent
NEXUS_NODE_NAME=my-raspberry-pi

# Database URL (Core only)
NEXUS_DATABASE_URL=sqlite:///data/nexus.db

# Log level
# Options: debug, info, warning, error
NEXUS_LOG_LEVEL=info

# Environment
# Options: development, production
NEXUS_ENV=development
