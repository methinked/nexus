FROM python:3.11-slim

LABEL maintainer="methinked"
LABEL description="Nexus Agent - Node management agent"

# Set working directory
WORKDIR /app

# Install system dependencies including Tesseract for OCR
RUN apt-get update && apt-get install -y \
    curl \
    tesseract-ocr \
    tesseract-ocr-eng \
    libtesseract-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements first for better caching
COPY requirements-agent.txt .
RUN pip install --no-cache-dir -r requirements-agent.txt

# Copy application code
COPY nexus/ ./nexus/
COPY pyproject.toml .

# Install the package in development mode
RUN pip install -e .

# Create data, logs, and sync directories
RUN mkdir -p /app/data /app/logs /app/sync

# Expose port
EXPOSE 8001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8001/health || exit 1

# Run the application
CMD ["uvicorn", "nexus.agent.main:app", "--host", "0.0.0.0", "--port", "8001"]
